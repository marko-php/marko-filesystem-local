{
    "name": "marko/filesystem-local",
    "description": "Local filesystem driver for Marko Framework",
    "type": "marko-module",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "marko/filesystem": "@dev",
        "ext-fileinfo": "*"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Filesystem\\Local\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Filesystem\\Local\\Tests\\": "tests/"
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
